#!/usr/bin/env bash
# oh-my-claudecode: Pre-commit Hook
# Runs type-safety linter on staged .ts files to enforce TypeScript best practices

set -euo pipefail

# Exit gracefully if husky is not installed (optional dependency)
if ! command -v husky &> /dev/null; then
  exit 0
fi

# Get staged TypeScript files
STAGED_TS_FILES=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.ts$' || true)

if [ -z "$STAGED_TS_FILES" ]; then
  exit 0
fi

echo "[TYPE SAFETY] Checking staged TypeScript files..."

# Run the type-safety linter on staged files
# The linter is expected to be available as a Node script
if command -v npx &> /dev/null; then
  # Try to run the linter if available
  # For now, just check if files compile with tsc
  npx tsc --noEmit 2>&1 | head -20 || {
    echo "[TYPE SAFETY] TypeScript compilation errors detected in staged files"
    echo "Fix errors before committing, or run: npx tsc --noEmit"
    exit 1
  }
fi

exit 0
