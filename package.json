{
  "name": "oh-my-claudecode",
  "version": "0.1.5",
  "description": "Cthulhu-themed agentic harness for Claude Code — 11 Elder God agents, lifecycle hooks, skill system, and multi-tier orchestration.",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js",
    "./cli": "./dist/cli/index.js"
  },
  "files": [
    "dist",
    "bin",
    "commands"
  ],
  "bin": {
    "oh-my-claudecode": "bin/oh-my-claudecode.js",
    "yith-mcp": "bin/yith-mcp.js"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "smoke": "node -e \"import('./dist/index.js').then(() => console.log('ok'))\"",
    "dev": "tsc --watch",
    "install-plugin": "bun src/cli/index.ts install",
    "doctor": "bun src/cli/index.ts doctor"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ragingstar2063/oh-my-claudecode.git"
  },
  "keywords": [
    "claude-code",
    "claude",
    "ai-agents",
    "cthulhu",
    "agentic",
    "orchestration"
  ],
  "license": "MIT",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.7",
    "zod": "^3.24.0"
  },
  "optionalDependencies": {
    "@xenova/transformers": "^2.17.2"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
